{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 'C:\\Python\\Excel2TeX\\.codex\\hooks\\check-codex-before-write.py'",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "WebSearch|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 'C:\\Python\\Excel2TeX\\.codex\\hooks\\suggest-gemini-research.py'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 'C:\\Python\\Excel2TeX\\.codex\\hooks\\check-codex-after-plan.py'",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 'C:\\Python\\Excel2TeX\\.codex\\hooks\\error-to-codex.py'",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 'C:\\Python\\Excel2TeX\\.codex\\hooks\\post-test-analysis.py'",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 'C:\\Python\\Excel2TeX\\.codex\\hooks\\log-cli-tools.py'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 'C:\\Python\\Excel2TeX\\.codex\\hooks\\lint-on-save.py'",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python3 'C:\\Python\\Excel2TeX\\.codex\\hooks\\post-implementation-review.py'",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"additionalContext\": \"Context compaction triggered. Key context: Check CLAUDE.md for project rules, .claude/docs/DESIGN.md for design decisions, .claude/rules/ for coding standards.\"}}'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 'C:\\Python\\Excel2TeX\\.codex\\hooks\\agent-router.py'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
